{
	# Disable Caddy's automatic HTTPS — Railway terminates TLS at its edge
	auto_https off
	admin off
}

# CI check: .github/workflows/caddy-validate.yml validates this file on every
# change (brief #370, guards the #371 corruption class).
:{$PORT:8080} {
	root * /srv
	encode gzip zstd
	file_server

	# Friendly 404
	handle_errors {
		respond "{err.status_code} {err.status_text}" {err.status_code}
	}

	# Long cache on static assets, no cache on HTML
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=604800, immutable"

	@html path *.html
	header @html Cache-Control "no-cache, must-revalidate"

	# Discourage indexing
	header X-Robots-Tag "noindex, nofollow"

	# Rep briefing: /outlet/{id} → outlet.html (id parsed by JS from pathname)
	rewrite /outlet/* /outlet.html

	# AI CPO - Dispensary: /cpo → cpo.html (brief #386 page split)
	rewrite /cpo /cpo.html

	# Workforce org chart: /cpo/org → cpo-org.html (brief #429)
	rewrite /cpo/org /cpo-org.html

	# Quality Board - Dispensary: /quality → quality.html (brief #386)
	rewrite /quality /quality.html

	# Ops dashboard retired in favor of the two-page split (brief #386):
	# executive triage/action layer moved to /cpo, latest-run quality detail
	# moved to /quality. Redirect so old /ops bookmarks keep working.
	redir /ops /quality 301

	# Always-current CEO status page: /status → status.html (brief #367)
	rewrite /status /status.html
}
